  <script>
    const mobileMenu = document.querySelector<HTMLDetailsElement>("[data-mobile-menu]");
    const donationSuccess = document.querySelector<HTMLElement>("#donation-success");

    mobileMenu?.querySelectorAll<HTMLAnchorElement>("[data-mobile-menu-link]").forEach((link) => {
      link.addEventListener("click", () => {
        mobileMenu.open = false;
      });
    });

    if (new URLSearchParams(window.location.search).get("donacion") === "enviada") {
      donationSuccess?.classList.remove("hidden");
      window.history.replaceState({}, "", window.location.pathname + window.location.hash);
    }

    donationSuccess?.querySelector<HTMLButtonElement>("[data-close-donation-success]")?.addEventListener("click", () => {
      donationSuccess.classList.add("hidden");
    });
  </script>
