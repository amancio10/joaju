---
import ActivitiesByYearPage from "../../components/ActivitiesByYearPage.astro";
import { activityYears } from "../../data/activities";

export function getStaticPaths() {
  return activityYears.map((year) => ({
    params: { year: String(year) }
  }));
}

const { year } = Astro.params;
---

<ActivitiesByYearPage lang="es" year={Number(year)} />
